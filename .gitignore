# ============================================================
# .gitignore — Food Store
# ============================================================

# ------------------------------------------------------------
# DATOS SENSIBLES 
# ------------------------------------------------------------
.env
.env.local
.env.*.local
*.key
*.pem
*.p12
*.pfx
secrets/

# ------------------------------------------------------------
# DEPENDENCIAS 
# ------------------------------------------------------------
node_modules/
backend/venv/
env/
venv/
ENV/

# Lock files 
yarn.lock
pnpm-lock.yaml

# ------------------------------------------------------------
# PYTHON 
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.installed.cfg
.Python
develop-eggs/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/

# ------------------------------------------------------------
# BUILD / DIST 
# ------------------------------------------------------------
dist/
build/
*.tsbuildinfo

# ------------------------------------------------------------
# TESTING 
# ------------------------------------------------------------
coverage/
htmlcov/
.nyc_output/
.pytest_cache/
.coverage
.coverage.*

# ------------------------------------------------------------
# LOGS 
# ------------------------------------------------------------
logs/
*.log
npm-debug.log*

# ------------------------------------------------------------
# IDE / SO 
# ------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ------------------------------------------------------------
# MISC 
# ------------------------------------------------------------
.turbo/
.cache/
.next/
.ruff_cache/

# ------------------------------------------------------------
# MEMORY / ENGRAM
# ------------------------------------------------------------
.engram/

# ============================================================
# NOTA: los siguientes directorios NO están en el .gitignore
# y sí se versionan intencionalmente:
#
#   .agents/        → skills e instrucciones del agente IA
#   openspec/       → artefactos del proceso SDD (cambios, specs)
#   docs/           → documentación de arquitectura y API
#   .github/        → workflows de CI/CD
#   AGENTS.md       → configuración del agente para el proyecto
#   GETTING-STARTED.md / README.md → documentación pública
# ============================================================
