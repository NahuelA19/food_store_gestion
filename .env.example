# ─────────────────────────────────────────────
#  Food Store — Entorno Local (Docker)
# ─────────────────────────────────────────────

# ── Base de Datos ──
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=food_store
DB_PORT=5433

# ── Backend (FastAPI) ──
ENVIRONMENT=development
DEBUG=true
BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
SECRET_KEY=change-this-insecure-dev-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000
BACKEND_PORT=8000

# ── Frontend (Vite) ──
VITE_API_URL=http://localhost:8000/api/v1
FRONTEND_PORT=5173

# ── MercadoPago Sandbox ──
# Obtené estas credenciales de: https://www.mercadopago.com.ar/developers/panel/app
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=
VITE_MP_PUBLIC_KEY=

# ── Ngrok (Para recibir webhooks de MercadoPago en local) ──
# 1. Registrate en https://dashboard.ngrok.com/get-started/your-authtoken
# 2. Pegá el token acá:
NGROK_AUTHTOKEN=

# 3. Una vez que corras `docker compose --profile ngrok up -d ngrok`, 
#    buscá la URL pública corriendo `curl http://localhost:4040/api/tunnels`
# 4. Pegá esa URL acá, seguida de /api/v1/payments/webhook
#    Ejemplo: https://1234abcd.ngrok-free.app/api/v1/payments/webhook
MP_NOTIFICATION_URL=http://localhost:8000/api/v1/payments/webhook
