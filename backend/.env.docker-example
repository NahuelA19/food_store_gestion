# ============================================================================
# Backend Environment Variables — DEVELOPMENT with Docker
# 
# Copy this file to backend/.env (or .env.local) and adjust as needed
# ============================================================================

# Server Configuration
ENVIRONMENT=development
DEBUG=True
HOST=0.0.0.0
PORT=8000

# Database — Using Docker PostgreSQL
# If using docker-compose, use this connection string:
# Default: PostgreSQL runs on port 5433 (to avoid conflicts with local PostgreSQL)
# DATABASE_URL=postgresql+asyncpg://food_store_user:root@postgres:5432/food_store
#
# If running from host machine instead of inside Docker:
# DATABASE_URL=postgresql+asyncpg://food_store_user:root@localhost:5433/food_store
#
# For testing (pytest), you can override with:
# TEST_DATABASE_URL=postgresql+asyncpg://food_store_user:root@localhost:5433/food_store_test
DATABASE_URL=postgresql+asyncpg://food_store_user:root@postgres:5432/food_store

# API Configuration
API_TITLE=Food Store API
API_VERSION=0.1.0

# Security - JWT Authentication
# IMPORTANT: Change this to a random string in production!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-development-secret-key-change-in-production-DO-NOT-COMMIT
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Logging
LOG_LEVEL=INFO

# CORS — Allow frontend during development
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000

# ============================================================================
# Docker-specific settings (optional)
# ============================================================================
# These are used by docker-compose.yml to set up the database
DB_USER=food_store_user
DB_PASSWORD=root
DB_NAME=food_store
DB_PORT=5432
